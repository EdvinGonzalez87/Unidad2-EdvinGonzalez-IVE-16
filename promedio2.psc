Algoritmo promedio
	Definir n1, n2, n3, n4, n5, x, prom Como Entero
	
	Escribir "Ingrese la nota 1"
	Leer n1
	Escribir "Ingrese la nota 2"
	Leer n2
	Escribir "Ingrese la nota 3"
	Leer n3
	Escribir "Ingrese la nota 4"
	Leer n4
	Escribir "Ingrese la nota 5"
	Leer n5
	x=n1+n2+n3+n4+n5
	prom=x/5
	Escribir promedio
	si
		(promedio>=70)
		Escribir Alumno aprobado
	SiNo
		Escribir Alumno Desaprobado
	FinSi
FinAlgoritmo
